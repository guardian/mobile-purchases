{
	"name": "mpapi-next-gen",
	"version": "1.0.0",
	"main": "index.js",
	"license": "MIT",
	"packageManager": "yarn@1.22.22",
	"scripts": {
		"build": "node esbuild.config.js",
		"package": "yarn build && cp -r node_modules dist/ && cd dist && zip -r ../lambda-package.zip .",
		"package:clean": "rm -f lambda-package.zip && rm -rf dist",
		"clean": "rm -rf dist",
		"lint:check": "eslint src --ext .ts,.tsx",
		"lint:fix": "eslint src --ext .ts,.tsx --fix",
		"format:check": "prettier --check \"src/**/*.ts\" \"*.{json,js,yml,yaml}\"",
		"format:fix": "prettier --write \"src/**/*.ts\" \"*.{json,js,yml,yaml}\"",
		"validate": "yarn lint:check && yarn format:check"
	},
	"dependencies": {
		"@aws-sdk/client-cloudwatch": "^3.1075.0",
		"@aws-sdk/client-dynamodb": "^3.1073.0",
		"@aws-sdk/client-s3": "^3.1071.0",
		"@aws-sdk/client-sqs": "^3.1073.0",
		"@aws-sdk/client-ssm": "^3.1071.0",
		"@aws-sdk/lib-dynamodb": "^3.1075.0",
		"@aws-sdk/util-dynamodb": "^3.996.5",
		"google-auth-library": "^10.7.0"
	},
	"devDependencies": {
		"@guardian/eslint-config": "16.0.0",
		"@guardian/prettier": "^10.0.0",
		"@types/aws-lambda": "^8.10.161",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.61.1",
		"@typescript-eslint/parser": "^8.61.1",
		"aws-lambda": "^1.0.7",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"prettier": "^3.8.4",
		"typescript": "^6.0.3"
	},
	"resolutions": {
		"fast-uri": "3.1.2",
		"fast-xml-builder": "1.1.7"
	}
}
