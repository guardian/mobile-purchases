{
	"name": "mpapi-next-gen",
	"version": "1.0.0",
	"main": "index.js",
	"license": "MIT",
	"packageManager": "yarn@1.22.22",
	"scripts": {
		"build": "webpack --env production",
		"clean": "rm -rf dist",
		"lint:check": "eslint src --ext .ts,.tsx",
		"lint:fix": "eslint src --ext .ts,.tsx --fix",
		"format:check": "prettier --check \"src/**/*.ts\" \"*.{json,js,yml,yaml}\"",
		"format:fix": "prettier --write \"src/**/*.ts\" \"*.{json,js,yml,yaml}\"",
		"validate": "yarn lint:check && yarn format:check"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.1073.0",
		"@aws-sdk/client-s3": "^3.1071.0",
		"@aws-sdk/client-ssm": "^3.1071.0",
		"google-auth-library": "^10.7.0"
	},
	"devDependencies": {
		"@guardian/eslint-config": "^14.0.1",
		"@guardian/prettier": "^10.0.0",
		"@types/aws-lambda": "^8.10.161",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.61.1",
		"@typescript-eslint/parser": "^8.61.1",
		"aws-lambda": "^1.0.7",
		"eslint": "^10.5.0",
		"prettier": "^3.8.4",
		"ts-loader": "^9.5.7",
		"typescript": "^6.0.3",
		"webpack": "^5.106.2",
		"webpack-cli": "^7.0.2"
	},
	"resolutions": {
		"fast-uri": "3.1.2",
		"fast-xml-builder": "1.1.7"
	}
}
